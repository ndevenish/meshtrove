# Copy to .env (auto-loaded by the backend in development).
# Every value can equally be passed as a CLI flag; see `meshtrove --help`.

DATABASE_URL=postgres://meshtrove:meshtrove@localhost:5432/meshtrove

# Content-addressed blob store location (created on demand)
MESHTROVE_STORE_DIR=./store

# Development conveniences: proxy the frontend to Vite, skip auth as admin
MESHTROVE_DEV_MODE=true
MESHTROVE_ANONYMOUS=true

# Default is 127.0.0.1:3000; 3000 is occupied by an ssh tunnel on this machine
MESHTROVE_BIND_ADDR=127.0.0.1:3001

# Persistent cookie signing key (optional in dev — ephemeral if unset).
# Generate with: openssl rand -base64 64 | tr -d '\n'
#MESHTROVE_COOKIE_KEY=

# Ensure an admin account exists at startup (username:password)
#MESHTROVE_CREATE_ADMIN=admin:changeme
