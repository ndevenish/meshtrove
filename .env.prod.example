# Production config for docker-compose.prod.yml. Copy to .env.prod and fill in:
#
#   cp .env.prod.example .env.prod
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# .env.prod is git-ignored — keep the real secrets out of version control.

# Postgres password. Used by the db container and by the app's DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-something-random

# Session cookie signing key — REQUIRED. Must be base64 of at least 64 bytes.
# Sessions are invalidated whenever it changes, so set it once and keep it.
#   openssl rand -base64 64 | tr -d '\n'
MESHTROVE_COOKIE_KEY=

# Bootstrap an admin account on first start (username:password). Runs on every
# start and resets that account's password to match, so once you've logged in
# and set a real password, blank this out and redeploy. Leave empty to skip.
MESHTROVE_CREATE_ADMIN=admin:change-me

# Host port to publish the app on (container always listens on 3000).
MESHTROVE_PORT=3000

# Version string baked into the image / `meshtrove --version` (optional).
# APP_VERSION=v1.0.0

# Log verbosity (error|warn|info|debug|trace, or per-module RUST_LOG syntax).
RUST_LOG=info
