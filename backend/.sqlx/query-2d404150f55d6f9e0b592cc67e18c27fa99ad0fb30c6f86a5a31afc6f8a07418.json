{
  "db_name": "PostgreSQL",
  "query": "SELECT f.id, f.blob_sha256, f.mime\n           FROM files f\n           LEFT JOIN model_variants v ON v.id = f.variant_id\n           WHERE (f.model_id = $1 OR v.model_id = $1)\n             AND f.mime LIKE 'image/%'\n           ORDER BY length(f.filename), f.filename",
