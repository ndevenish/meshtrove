{
  "db_name": "PostgreSQL",
  "query": "SELECT f.path as \"path!\", count(*) as \"files!\",\n                  coalesce(sum(b.size), 0)::bigint as \"bytes!\"\n           FROM files f\n           JOIN blobs b ON b.sha256 = f.blob_sha256\n           WHERE f.import_id = $1\n           GROUP BY f.path\n           ORDER BY f.path",
