{
  "db_name": "PostgreSQL",
  "query": "SELECT f.id, f.blob_sha256, f.path, f.filename, f.mime,\n                  f.kind as \"kind: FileKind\", f.created_at, b.size\n           FROM files f JOIN blobs b ON b.sha256 = f.blob_sha256\n           WHERE f.import_id = $1\n           ORDER BY f.path, f.filename",
