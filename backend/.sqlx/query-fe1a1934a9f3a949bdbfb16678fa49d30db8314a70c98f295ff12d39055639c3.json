{
  "db_name": "PostgreSQL",
  "query": "SELECT f.id, f.filename, f.kind as \"kind: crate::routes::files::FileKind\"\n           FROM files f\n           JOIN imports i ON i.id = f.import_id\n           WHERE f.import_id IS NOT NULL\n             AND NOT i.is_export\n             AND NOT EXISTS (\n               SELECT 1 FROM jobs j\n               WHERE j.kind = 'import_archive'\n                 AND j.payload->>'archive_file_id' = f.id::text\n             )",
