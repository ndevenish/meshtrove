  "db_name": "PostgreSQL",
  "query": "UPDATE jobs SET status = 'running', started_at = now(), attempts = attempts + 1\n           WHERE id = (\n               SELECT id FROM jobs\n               WHERE status = 'queued' AND run_after <= now()\n                 AND (kind = ANY($1)) = $2\n               ORDER BY priority DESC, id\n               FOR UPDATE SKIP LOCKED\n               LIMIT 1\n           )\n           RETURNING id, kind, payload, attempts, max_attempts",
