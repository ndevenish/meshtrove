  "query": "SELECT id, kind, payload, status as \"status: JobStatus\", attempts, max_attempts,\n                  last_error, created_at, started_at, finished_at\n           FROM jobs\n           WHERE ($1 = '' OR status = $1::job_status)\n           ORDER BY id DESC LIMIT $2",
